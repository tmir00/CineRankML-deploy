{
  "annotations": { "list": [] },
  "description": "Online recommendation serving metrics. Offline train/eval metrics live in MLflow.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (endpoint, status) (rate(recommend_requests_total[1m]))",
          "legendFormat": "{{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "recommend_requests_total",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(recommend_errors_total[5m])) / clamp_min(sum(rate(recommend_requests_total[5m])), 1)",
          "legendFormat": "error rate",
          "refId": "A"
        },
        {
          "expr": "sum by (error_type) (rate(recommend_errors_total[5m]))",
          "legendFormat": "{{error_type}}",
          "refId": "B"
        }
      ],
      "title": "recommend_errors_total / error rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(recommend_latency_ms_bucket[5m])))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(recommend_latency_ms_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(recommend_latency_ms_bucket[5m])))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "C"
        }
      ],
      "title": "recommend_latency_ms (p50/p95/p99)",
      "type": "timeseries"
    },
